<service>
  <id>account-fee-service</id>
  <name>会计服务费收款登记系统</name>
  <description>会计服务费收款登记系统后台服务</description>

  <executable>java</executable>
  <arguments>
    -server
    -Dfile.encoding=UTF-8
    -Duser.timezone=Asia/Shanghai
    -Xms512m
    -Xmx1024m
    -jar D:\account-fee-system\app\account-fee-system.jar
    --spring.config.location=D:\account-fee-system\config\application-prod.yml
  </arguments>

  <logpath>D:\account-fee-system\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10485760</sizeThreshold>
    <keepFiles>10</keepFiles>
  </log>

  <startmode>Automatic</startmode>
</service>
